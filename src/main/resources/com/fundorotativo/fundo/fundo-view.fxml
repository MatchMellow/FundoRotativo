<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.fundorotativo.fundo.FundoController"
      stylesheets="@styles.css">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <!-- Título -->
    <Label text="Fundo Rotativo Solidário" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>

    <!-- Botões -->
    <Button text="Pessoa" onAction="#onPessoaButtonClick"/>
    <Button text="Empréstimos" onAction="#onEmprestimosButtonClick"/>
    <Button text="Parcelas" onAction="#onParcelasButtonClick"/>
    <Button text="Contratos" onAction="#onContratosButtonClick"/>
    <Button text="Relatórios" onAction="#onRelatoriosButtonClick"/>
    <Button text="Sair" onAction="#onSairButtonClick"/>
</VBox>
